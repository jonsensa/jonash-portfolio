---
import Layout from '../layouts/Layout.astro';
import ArtworkGrid from '../components/ArtworkGrid.astro';
import { getCollection } from 'astro:content';

const galleryData = await getCollection('artwork');
const artPieces = galleryData.map(entry => entry.data);
---

<Layout title="Art Gallery | Jonash">
    <div class="max-w-5xl mx-auto px-6 py-12 md:p-14 mt-8 mb-20 bg-white/[0.02] backdrop-blur-3xl border border-white/5 shadow-2xl rounded-[2rem]">
        <header class="mb-16">
            <h1 class="text-5xl font-black text-white mb-4 tracking-tight">Art Gallery</h1>
            <p class="text-xl text-slate-400 max-w-2xl">
                Visual experiments, digital paintings, and design concepts I've been working on.
            </p>
        </header>

        <ArtworkGrid images={artPieces} />
    </div>
</Layout>
