---
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');
---

<Layout title="Projects | Jonash">
    <div class="max-w-5xl mx-auto px-6 py-12 md:p-14 mt-8 mb-20 bg-white/[0.02] backdrop-blur-3xl border border-white/5 shadow-2xl rounded-[2rem]">
        <header class="mb-16">
            <h1 class="text-5xl font-black text-white mb-4 tracking-tight">Software Projects</h1>
            <p class="text-xl text-slate-400 max-w-2xl">
                A collection of things I've built. From front-end experiments to full-stack applications.
            </p>
        </header>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {allProjects.map(project => (
                <ProjectCard 
                    title={project.data.title}
                    description={project.data.description}
                    tags={project.data.tags}
                    link={`/projects/${project.slug}`}
                    image={project.data.image}
                />
            ))}
        </div>
    </div>
</Layout>
