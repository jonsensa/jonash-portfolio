---
import '../styles/global.css';

interface Props {
	title: string;
}

const { title } = Astro.props;
---
<!doctype html>
<html lang="en" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body class="bg-slate-950 text-slate-200 antialiased min-h-screen flex flex-col selection:bg-purple-500/30 relative overflow-x-hidden">
		
        <!-- Global Decorative Background Glows -->
        <div class="fixed top-0 right-0 -mr-[20vw] -mt-[10vh] w-[50vw] h-[50vw] bg-indigo-500/10 rounded-full blur-[120px] pointer-events-none mix-blend-screen -z-50"></div>
        <div class="fixed bottom-0 left-0 -ml-[20vw] -mb-[10vh] w-[60vw] h-[60vw] bg-purple-500/10 rounded-full blur-[140px] pointer-events-none mix-blend-screen -z-50"></div>
        <div class="fixed top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[80vw] h-[80vw] bg-slate-900/50 rounded-full blur-[100px] pointer-events-none -z-40"></div>

		<nav class="fixed w-full z-50 top-0 border-b border-white/5 bg-slate-950/50 backdrop-blur-xl">
			<div class="max-w-5xl mx-auto px-6 h-16 flex items-center justify-between">
				<a href="/" class="text-xl font-bold tracking-tighter text-white">
					Jonash<span class="text-fuchsia-500">.</span>
				</a>
				<div class="hidden md:flex gap-8 text-sm font-medium text-slate-400">
					<a href="/" class="hover:text-white transition-colors">Home</a>
					<a href="/projects" class="hover:text-white transition-colors">Projects</a>
					<a href="/artwork" class="hover:text-white transition-colors">Art Gallery</a>
					<a href="/blog" class="hover:text-white transition-colors">Blog</a>
				</div>
			</div>
		</nav>

		<main class="flex-grow pt-24 pb-16 relative z-10">
			<slot />
		</main>

		<footer class="border-t border-white/5 py-8 text-center text-sm text-slate-500 relative z-20 bg-slate-950/50 backdrop-blur-md mt-auto">
			<p>Built with Astro & Tailwind. © {new Date().getFullYear()} Jonash.</p>
		</footer>

	</body>
</html>
