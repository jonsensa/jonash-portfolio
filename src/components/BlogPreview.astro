---
interface Props {
    title: string;
    date: string;
    excerpt: string;
    readTime: string;
    link?: string;
}

const { title, date, excerpt, readTime, link = "#" } = Astro.props;
---

<a href={link} class="group block p-6 bg-slate-900/50 border border-white/5 rounded-2xl hover:bg-slate-800/80 hover:border-fuchsia-500/50 transition-all duration-300">
    <div class="flex items-center gap-3 text-sm text-slate-500 mb-3">
        <time datetime={date}>{date}</time>
        <span class="w-1 h-1 rounded-full bg-slate-700"></span>
        <span>{readTime} read</span>
    </div>
    
    <h3 class="text-xl font-bold text-white mb-2 group-hover:text-fuchsia-400 transition-colors">{title}</h3>
    
    <p class="text-slate-400 line-clamp-2">{excerpt}</p>
    
    <div class="mt-4 flex items-center gap-2 text-sm font-medium text-fuchsia-500 opacity-0 -translate-x-2 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-300">
        Read Article
        <svg xmlns="http://www.w3.org/-2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 256 256"><path d="M221.66,133.66l-72,72a8,8,0,0,1-11.32-11.32L196.69,136H40a8,8,0,0,1,0-16H196.69L138.34,61.66a8,8,0,0,1,11.32-11.32l72,72A8,8,0,0,1,221.66,133.66Z"></path></svg>
    </div>
</a>
