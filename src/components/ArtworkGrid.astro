---
interface Props {
    images: {
        src: string;
        alt: string;
        title: string;
    }[];
}

const { images } = Astro.props;
---

<!-- Pinterest-style Masonry Layout -->
<div class="columns-1 sm:columns-2 md:columns-3 lg:columns-4 gap-4 space-y-4">
    {images.map((image) => (
        <button 
            type="button"
            class="artwork-trigger group relative w-full rounded-xl overflow-hidden bg-slate-900 border border-white/5 cursor-zoom-in outline-none focus:ring-2 focus:ring-fuchsia-500 block break-inside-avoid"
            data-src={image.src}
            data-alt={image.alt}
            data-title={image.title}
        >
            
            <!-- Artwork Image (Natural Aspect Ratio) -->
            <div class="w-full relative overflow-hidden rounded-xl group-hover:shadow-[0_0_20px_rgba(217,70,239,0.3)] transition-all duration-500">
                <img src={image.src} alt={image.alt} class="w-full h-auto block group-hover:scale-105 transition-transform duration-700" loading="lazy" />
                
                <!-- Hover Overlay -->
                <!-- Use an inset to cover the actual image size perfectly -->
                <div class="absolute inset-0 bg-slate-950/80 p-6 flex flex-col justify-end opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                    <h3 class="text-white font-bold text-lg text-left">{image.title}</h3>
                    <p class="text-slate-400 text-sm mt-1 text-left line-clamp-2">{image.alt}</p>
                    <div class="mt-4 flex items-center gap-2 text-sm font-medium text-fuchsia-400">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 256 256"><path d="M224,48V88a8,8,0,0,1-16,0V59.31L133.66,133.66a8,8,0,0,1-11.32-11.32L196.69,48H168a8,8,0,0,1,0-16h48A8,8,0,0,1,224,48ZM104,168V196.69L29.66,122.34a8,8,0,0,0-11.32,11.32L92.69,208H64a8,8,0,0,0,0,16h48a8,8,0,0,0,8-8V168a8,8,0,0,0-16,0Z"></path></svg>
                        Expand
                    </div>
                </div>
            </div>

        </button>
    ))}
</div>

<!-- Lightbox Modal -->
<div id="lightbox" class="fixed inset-0 z-[100] hidden items-center justify-center bg-slate-950/95 backdrop-blur-md transition-opacity duration-300 opacity-0 cursor-zoom-out p-4 md:p-12">
    <!-- Close Button -->
    <button id="lightbox-close" class="absolute top-6 right-6 text-white/70 hover:text-white bg-white/10 p-3 rounded-full hover:bg-white/20 transition-colors z-[110]" aria-label="Close image">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 256 256"><path d="M205.66,194.34a8,8,0,0,1-11.32,11.32L128,139.31,61.66,205.66a8,8,0,0,1-11.32-11.32L116.69,128,50.34,61.66A8,8,0,0,1,61.66,50.34L128,116.69l66.34-66.35a8,8,0,0,1,11.32,11.32L139.31,128Z"></path></svg>
    </button>
    
    <!-- Image Container. No max-height constraint to let it be natural. -->
    <div class="relative max-w-7xl mx-auto flex flex-col items-center cursor-default h-[90vh] justify-center" id="lightbox-content">
        <!-- The big, uncropped image -->
        <img id="lightbox-img" src="" alt="" class="max-w-full max-h-full object-contain shadow-[0_0_50px_rgba(0,0,0,0.5)] rounded-lg transition-transform duration-300 opacity-0 scale-95" />
        
        <!-- Caption -->
        <div class="absolute bottom-[-2rem] text-center bg-slate-900/80 backdrop-blur-xl px-8 py-4 rounded-2xl border border-white/10 shadow-2xl max-w-2xl transform transition-transform duration-300 opacity-0 translate-y-4" id="lightbox-caption">
            <h3 id="lightbox-title" class="text-white font-bold text-2xl md:text-3xl tracking-tight mb-2"></h3>
            <p id="lightbox-desc" class="text-slate-400 text-sm md:text-base leading-relaxed"></p>
        </div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        const lightbox = document.getElementById('lightbox');
        const lightboxImg = document.getElementById('lightbox-img');
        const lightboxTitle = document.getElementById('lightbox-title');
        const lightboxDesc = document.getElementById('lightbox-desc');
        const lightboxClose = document.getElementById('lightbox-close');
        const lightboxCaption = document.getElementById('lightbox-caption');
        const triggers = document.querySelectorAll('.artwork-trigger');

        if (!lightbox) return;

        const openLightbox = (src: string, title: string, alt: string) => {
            // Set uncropped full source
            if (lightboxImg) {
                lightboxImg.setAttribute('src', src);
                lightboxImg.setAttribute('alt', alt);
            }
            if (lightboxTitle) lightboxTitle.textContent = title;
            if (lightboxDesc) lightboxDesc.textContent = alt;

            lightbox.classList.remove('hidden');
            lightbox.classList.add('flex');
            
            // Allow background scroll by NOT doing: document.body.style.overflow = 'hidden';
            
            requestAnimationFrame(() => {
                lightbox.classList.remove('opacity-0');
                if (lightboxImg) {
                    lightboxImg.classList.remove('opacity-0', 'scale-95');
                    lightboxImg.classList.add('opacity-100', 'scale-100');
                }
                if (lightboxCaption) {
                    lightboxCaption.classList.remove('opacity-0', 'translate-y-4');
                    lightboxCaption.classList.add('opacity-100', 'translate-y-0');
                }
            });
        };

        const closeLightbox = () => {
            lightbox.classList.add('opacity-0');
            if (lightboxImg) {
                lightboxImg.classList.add('opacity-0', 'scale-95');
                lightboxImg.classList.remove('opacity-100', 'scale-100');
            }
            if (lightboxCaption) {
                lightboxCaption.classList.add('opacity-0', 'translate-y-4');
                lightboxCaption.classList.remove('opacity-100', 'translate-y-0');
            }
            
            setTimeout(() => {
                lightbox.classList.add('hidden');
                lightbox.classList.remove('flex');
                if (lightboxImg) lightboxImg.setAttribute('src', ''); 
            }, 300);
        };

        triggers.forEach(trigger => {
            trigger.addEventListener('click', () => {
                const src = trigger.getAttribute('data-src');
                const title = trigger.getAttribute('data-title');
                const alt = trigger.getAttribute('data-alt');
                if (src && title && alt) openLightbox(src, title, alt);
            });
        });

        if (lightboxClose) {
            lightboxClose.addEventListener('click', closeLightbox);
        }

        lightbox.addEventListener('click', (e) => {
            if (e.target === lightbox || e.target === document.getElementById('lightbox-content')) {
                closeLightbox();
            }
        });

        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape' && !lightbox.classList.contains('hidden')) {
                closeLightbox();
            }
        });
    });
</script>
